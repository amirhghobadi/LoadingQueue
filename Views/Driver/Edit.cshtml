@model LoadingQueue.Models.Driver

@{
    ViewData["Title"] = "ویرایش راننده";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow">

            <div class="card-header bg-warning">

                <h4>

                    <i class="bi bi-pencil-square"></i>

                    ویرایش راننده

                </h4>

            </div>

            <div class="card-body">

                <form asp-action="Edit">

                    <input asp-for="Id" type="hidden"/>

                    <input asp-for="RegisterDate" type="hidden"/>

                    <input asp-for="IsDeleted" type="hidden"/>

                    <input asp-for="DeletedAt" type="hidden"/>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label asp-for="FullName"></label>

                            <input asp-for="FullName" class="form-control"/>

                            <span asp-validation-for="FullName" class="text-danger"></span>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label asp-for="PhoneNumber"></label>

                            <input asp-for="PhoneNumber" class="form-control"/>

                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>

                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label asp-for="CarNumber"></label>

                            <input asp-for="CarNumber" class="form-control"/>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label asp-for="CardNumberOrSheba"></label>

                            <input asp-for="CardNumberOrSheba" class="form-control"/>

                        </div>

                    </div>

                    <div class="d-flex justify-content-between">

                        <a asp-action="Index" class="btn btn-secondary">

                            بازگشت

                        </a>

                        <button class="btn btn-warning">

                            ذخیره تغییرات

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts{

<partial name="_ValidationScriptsPartial"/>

}