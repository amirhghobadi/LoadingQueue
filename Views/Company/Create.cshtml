@model LoadingQueue.Models.Company

@{
    ViewData["Title"] = "شرکت جدید";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow">

            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">ثبت شرکت جدید</h5>
            </div>

            <div class="card-body">

                <form asp-action="Create" method="post">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="NationalId" class="form-label"></label>
                            <input asp-for="NationalId" class="form-control" />
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="IsActive" class="form-label d-block"></label>
                            <input asp-for="IsActive" class="form-check-input" checked />
                        </div>

                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="mt-4 d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">بازگشت</a>
                        <button type="submit" class="btn btn-success">ثبت شرکت</button>
                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}