@{
    ViewData["Title"] = "ورود به سیستم";
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - سیستم صف بارگیری</title>

    <!-- CSS Libraries -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <!-- Custom Login CSS -->
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>

<div class="login-container">
    <div class="login-card">
        
        <!-- Login Header -->
        <div class="login-header">
            <div class="login-logo">🚚</div>
            <h2 class="login-title">سیستم صف بارگیری</h2>
            <p class="login-subtitle">مدیریت هوشمند بارگیری و نوبت‌دهی</p>
        </div>

        <!-- Login Body -->
        <div class="login-body">
            
            <!-- Error Messages -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-message">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div><i class="bi bi-exclamation-circle"></i> @error.ErrorMessage</div>
                    }
                </div>
            }

            <!-- Login Form -->
            <form method="post" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                
                <!-- Username Field -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="bi bi-person"></i>
                        نام کاربری یا ایمیل
                    </label>
                    <input type="text" 
                           name="username" 
                           class="form-input" 
                           placeholder="نام کاربری خود را وارد کنید"
                           required 
                           autofocus />
                </div>

                <!-- Password Field -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="bi bi-lock"></i>
                        رمز عبور
                    </label>
                    <input type="password" 
                           name="password" 
                           class="form-input" 
                           placeholder="رمز عبور خود را وارد کنید"
                           required />
                </div>

                <!-- Remember Me -->
                <div class="remember-me">
                    <input type="checkbox" 
                           name="rememberMe" 
                           id="rememberMe" 
                           value="true" />
                    <label for="rememberMe">مرا به خاطر بسپار</label>
                </div>

                <!-- Login Button -->
                <button type="submit" class="login-btn">
                    <i class="bi bi-box-arrow-in-right"></i>
                    ورود به سیستم
                </button>

            </form>

        </div>

        <!-- Login Footer -->
        <div class="login-footer">
            <i class="bi bi-shield-lock"></i>
            تمام اطلاعات شما رمزگذاری شده‌اند
        </div>

    </div>
</div>

<!-- JS Libraries -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/theme.js" asp-append-version="true"></script>

</body>
</html>
